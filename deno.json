{
	"name": "@0xc0de666/ts-rust",
	"description": "Rust-like Result and Option Utilities for TypeScript",
	"version": "1.0.0",
	"author": "D43M0N",
	"repository": "https://github.com/0xC0DE666/ts_rust",
	"exports": "./mod.ts",
	"license": "MIT",
	"compilerOptions": {
		"strict": true,
		"lib": [
			"deno.ns",
			"dom"
		]
	},
	"imports": {
		"@std/assert": "jsr:@std/assert@1"
	},
	"tasks": {
		"dev": "deno run --watch src/main.ts",
		"test": "deno test src/test.ts",
		"lint": "deno lint",
		"fmt": "deno fmt"
	},
	"lint": {
		"rules": {
			"tags": [
				"recommended"
			]
		}
	},
	"fmt": {
		"options": {
			"useTabs": true,
			"indentWidth": 4,
			"lineWidth": 80,
			"singleQuote": false
		}
	},
	"test": {
		"include": [
			"src/test.ts"
		]
	}
}
