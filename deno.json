{
	"name": "@0xc0de666/ts-rust",
	"description": "Rust-like Result and Option Utilities for TypeScript",
	"version": "1.2.0",
	"author": "D43M0N",
	"repository": "https://github.com/0xC0DE666/ts_rust",
	"exports": "./mod.ts",
	"license": "MIT",
	"compilerOptions": {
		"strict": true,
		"lib": [
			"deno.ns",
			"dom"
		]
	},
	"imports": {
		"@std/assert": "jsr:@std/assert@1"
	},
	"tasks": {
		"test": "deno test src/test.ts",
		"lint": "deno lint",
		"fmt": "deno fmt",
		"example:basic-result": "deno run examples/basic-result.ts",
		"example:basic-option": "deno run examples/basic-option.ts",
		"example:advanced": "deno run --allow-net examples/advanced-pipeline.ts",
		"examples": "deno task example:basic-result && deno task example:basic-option && deno task example:advanced"
	},
	"lint": {
		"rules": {
			"tags": [
				"recommended"
			]
		}
	},
	"fmt": {
		"options": {
			"useTabs": true,
			"indentWidth": 4,
			"lineWidth": 100,
			"singleQuote": false
		}
	},
	"test": {
		"include": [
			"src/test.ts"
		]
	}
}
